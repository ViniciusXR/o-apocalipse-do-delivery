# Porta do microsservico de checkout (rota /api/v1/checkout)
PORT=3000

# URLs das dependencias externas.
# MODO NORMAL (sem caos): aponte direto para os simuladores.
#   GATEWAY_URL=http://127.0.0.1:4001
#   CACHE_URL=http://127.0.0.1:4002
# MODO CAOS (com Toxiproxy): aponte para as portas dos proxies.
#   GATEWAY_URL=http://127.0.0.1:21001
#   CACHE_URL=http://127.0.0.1:21002
GATEWAY_URL=http://127.0.0.1:4001
CACHE_URL=http://127.0.0.1:4002

# Portas dos simuladores de infraestrutura
GATEWAY_PORT=4001
CACHE_PORT=4002

# --- RF04: Timeout / Retry / Backoff ---
GATEWAY_TIMEOUT_MS=2000      # RN04: timeout rigido de 2s por tentativa
RETRY_MAX_ATTEMPTS=3         # RN05: ate 3 retentativas adicionais
RETRY_BACKOFF_MS=500         # RN06: backoff fixo de 500ms
RETRY_JITTER_MS=250          # jitter aleatorio adicionado ao backoff

# --- RF05: Circuit Breaker ---
BREAKER_ERROR_THRESHOLD=0.5  # RN07: abre se taxa de erro de rede > 50%
BREAKER_VOLUME_THRESHOLD=10  # minimo de chamadas na janela antes de avaliar
BREAKER_WINDOW_SIZE=20       # tamanho da janela deslizante de resultados
BREAKER_RESET_TIMEOUT_MS=3000 # tempo em OPEN antes de tentar HALF_OPEN

# --- Protecao do banco (Thundering Herd) ---
DB_MAX_CONCURRENCY=20        # limite do "pool de conexoes" do banco
DB_QUEUE_TIMEOUT_MS=3000     # tempo maximo aguardando uma vaga no pool

# Endereco admin do Toxiproxy (usado pelos scripts de caos)
TOXIPROXY_HOST=127.0.0.1
TOXIPROXY_PORT=8474
